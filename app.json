{
  "expo": {
    "name": "Tata Pravesh Inventory",
    "slug": "TataPraveshApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Tata-Pravesh-Favicon.png",
    "scheme": "tatapraveshapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/Tata-Pravesh-Favicon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.asimd2472.TataPraveshApp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Tata-Pravesh-Favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Tata-Pravesh-Favicon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "853817ba-9fa6-4b82-85f5-85a594ae1834"
      }
    }
  }
}
